# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database (MongoDB Atlas connection string) ----
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cosmetic-shop

# ---- Auth ----
# Generate a long random string, e.g. run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ---- CORS: URL where the React app runs ----
CLIENT_URL=http://localhost:5173

# ---- Razorpay (from dashboard.razorpay.com -> Settings -> API Keys) ----
# Use test keys (rzp_test_...) while developing, live keys after KYC approval.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Shop identity (shown in the Razorpay checkout popup) ----
SHOP_NAME=ShagunShopping

# Email delivery (welcome, order confirmations, OTP verification codes)
# Gmail: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it as SMTP_PASS.
# Leave these empty in development to print emails to the console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=shagunshopping.meerut@gmail.com
SMTP_PASS=
MAIL_FROM="ShagunShopping <shagunshopping.meerut@gmail.com>"

# ---- Shipping rules (amounts in INR) ----
FREE_SHIPPING_ABOVE=999
SHIPPING_FEE=49

# ---- Seed script: initial admin account (CHANGE THESE, then run: npm run seed) ----
ADMIN_NAME=Shop Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345
